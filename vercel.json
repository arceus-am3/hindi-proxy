{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/proxy.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/v1/proxy",
      "destination": "/api/proxy"
    },
    {
      "source": "/api/v2/proxy",
      "destination": "/api/proxy"
    }
  ]
}
